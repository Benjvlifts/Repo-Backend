        @NotBlank(message = "El email es obligatorio")
        @Email
        private String email;

        @NotBlank(message = "La contraseña es obligatoria")
        private String password;
    }

    // ── Response: Token JWT ──────────────────────────────────────────────────
    @Data
    @Builder
    @NoArgsConstructor
    @AllArgsConstructor
    public static class AuthResponse {
        private String token;
        private String type;
        private Long userId;
