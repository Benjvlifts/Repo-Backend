{
  "info": {
    "name": "Innovatech Solutions - Backend (ms-auth, ms-proyectos, ms-recursos, ms-analitica, ms-notif)",
    "description": "Colección Postman con la especificación de endpoints de los microservicios backend de Innovatech Solutions. Incluye autenticación JWT, gestión de proyectos, recursos humanos, analítica y notificaciones.\n\nVariables de entorno requeridas:\n- auth_url (default http://localhost:8081)\n- proyectos_url (default http://localhost:8082)\n- recursos_url (default http://localhost:8083)\n- analitica_url (default http://localhost:8084)\n- notif_url (default http://localhost:8085)\n- token (se completa automáticamente tras ejecutar Login)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url", "value": "http://localhost:8081" },
    { "key": "proyectos_url", "value": "http://localhost:8082" },
    { "key": "recursos_url", "value": "http://localhost:8083" },
    { "key": "analitica_url", "value": "http://localhost:8084" },
    { "key": "notif_url", "value": "http://localhost:8085" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "ms-auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Benjamin Valdes\",\n  \"email\": \"benjamin@innovatech.cl\",\n  \"password\": \"secret123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('token', body.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"benjamin@innovatech.cl\",\n  \"password\": \"secret123\"\n}"
            },
            "url": { "raw": "{{auth_url}}/api/auth/login", "host": ["{{auth_url}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Validar token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": { "raw": "{{auth_url}}/api/auth/validate", "host": ["{{auth_url}}"], "path": ["api", "auth", "validate"] }
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{auth_url}}/api/auth/users", "host": ["{{auth_url}}"], "path": ["api", "auth", "users"] }
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{auth_url}}/api/auth/users/1", "host": ["{{auth_url}}"], "path": ["api", "auth", "users", "1"] }
          }
        },
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{auth_url}}/api/auth/health", "host": ["{{auth_url}}"], "path": ["api", "auth", "health"] }
          }
        }
      ]
    },
    {
      "name": "ms-proyectos",
      "item": [
        {
          "name": "Crear proyecto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Migración a la nube\",\n  \"description\": \"Migración de infraestructura on-premise a AWS\",\n  \"type\": \"INFRASTRUCTURE\",\n  \"status\": \"PLANNED\",\n  \"managerId\": 2,\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-12-01\",\n  \"cloudProvider\": \"AWS\",\n  \"budgetUsd\": 50000\n}"
            },
            "url": { "raw": "{{proyectos_url}}/api/projects", "host": ["{{proyectos_url}}"], "path": ["api", "projects"] }
          }
        },
        {
          "name": "Listar proyectos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{proyectos_url}}/api/projects?status=IN_PROGRESS",
              "host": ["{{proyectos_url}}"],
              "path": ["api", "projects"],
              "query": [{ "key": "status", "value": "IN_PROGRESS", "disabled": true }, { "key": "type", "value": "SOFTWARE", "disabled": true }]
            }
          }
        },
        {
          "name": "Obtener proyecto por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{proyectos_url}}/api/projects/1", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1"] }
          }
        },
        {
          "name": "Listar proyectos por manager",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{proyectos_url}}/api/projects/manager/2", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "manager", "2"] }
          }
        },
        {
          "name": "Actualizar proyecto",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Migración a la nube (actualizado)\",\n  \"description\": \"Alcance ampliado a multi-cloud\",\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": { "raw": "{{proyectos_url}}/api/projects/1", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1"] }
          }
        },
        {
          "name": "Cambiar estado del proyecto",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"COMPLETED\"\n}" },
            "url": { "raw": "{{proyectos_url}}/api/projects/1/status", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1", "status"] }
          }
        },
        {
          "name": "Asignar empleado",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": 3,\n  \"employeeName\": \"Ignacio Munoz\"\n}" },
            "url": { "raw": "{{proyectos_url}}/api/projects/1/assign", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1", "assign"] }
          }
        },
        {
          "name": "Desasignar empleado",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{proyectos_url}}/api/projects/1/assign", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1", "assign"] }
          }
        },
        {
          "name": "Eliminar proyecto",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{proyectos_url}}/api/projects/1", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1"] }
          }
        },
        {
          "name": "Agregar nota de avance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Avance del 40% en la migración de bases de datos.\"\n}" },
            "url": { "raw": "{{proyectos_url}}/api/projects/1/notes", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1", "notes"] }
          }
        },
        {
          "name": "Listar notas de un proyecto",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{proyectos_url}}/api/projects/1/notes", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1", "notes"] }
          }
        },
        {
          "name": "Revisar nota de avance",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"APPROVED\"\n}" },
            "url": { "raw": "{{proyectos_url}}/api/projects/1/notes/1/review", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "1", "notes", "1", "review"] }
          }
        },
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{proyectos_url}}/api/projects/health", "host": ["{{proyectos_url}}"], "path": ["api", "projects", "health"] }
          }
        }
      ]
    },
    {
      "name": "ms-recursos",
      "item": [
        {
          "name": "Crear recurso",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ignacio Munoz\",\n  \"email\": \"ignacio@innovatech.cl\",\n  \"department\": \"Ingeniería\",\n  \"role\": \"DEVELOPER\",\n  \"skills\": \"Java, Spring Boot, Kafka\"\n}"
            },
            "url": { "raw": "{{recursos_url}}/api/resources", "host": ["{{recursos_url}}"], "path": ["api", "resources"] }
          }
        },
        {
          "name": "Listar recursos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{recursos_url}}/api/resources", "host": ["{{recursos_url}}"], "path": ["api", "resources"] }
          }
        },
        {
          "name": "Listar recursos disponibles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{recursos_url}}/api/resources/available", "host": ["{{recursos_url}}"], "path": ["api", "resources", "available"] }
          }
        },
        {
          "name": "Listar recursos por departamento",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{recursos_url}}/api/resources/department/Ingenieria", "host": ["{{recursos_url}}"], "path": ["api", "resources", "department", "Ingenieria"] }
          }
        },
        {
          "name": "Obtener recurso por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{recursos_url}}/api/resources/1", "host": ["{{recursos_url}}"], "path": ["api", "resources", "1"] }
          }
        },
        {
          "name": "Actualizar disponibilidad",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"available\": false\n}" },
            "url": { "raw": "{{recursos_url}}/api/resources/1/availability", "host": ["{{recursos_url}}"], "path": ["api", "resources", "1", "availability"] }
          }
        },
        {
          "name": "Asignar recurso a proyecto",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"projectId\": 1,\n  \"projectName\": \"Migración a la nube\"\n}" },
            "url": { "raw": "{{recursos_url}}/api/resources/1/assign", "host": ["{{recursos_url}}"], "path": ["api", "resources", "1", "assign"] }
          }
        },
        {
          "name": "Eliminar recurso",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{recursos_url}}/api/resources/1", "host": ["{{recursos_url}}"], "path": ["api", "resources", "1"] }
          }
        },
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{recursos_url}}/api/resources/health", "host": ["{{recursos_url}}"], "path": ["api", "resources", "health"] }
          }
        }
      ]
    },
    {
      "name": "ms-analitica",
      "item": [
        {
          "name": "Listar métricas generales",
          "request": {
            "method": "GET",
            "url": { "raw": "{{analitica_url}}/api/v1/analitica/metricas", "host": ["{{analitica_url}}"], "path": ["api", "v1", "analitica", "metricas"] }
          }
        },
        {
          "name": "Obtener métricas de un proyecto",
          "request": {
            "method": "GET",
            "url": { "raw": "{{analitica_url}}/api/v1/analitica/metricas/proyecto/1", "host": ["{{analitica_url}}"], "path": ["api", "v1", "analitica", "metricas", "proyecto", "1"] }
          }
        }
      ]
    },
    {
      "name": "ms-notif",
      "item": [
        {
          "name": "Listar notificaciones de un proyecto",
          "request": {
            "method": "GET",
            "url": { "raw": "{{notif_url}}/api/v1/notificaciones/proyecto/1", "host": ["{{notif_url}}"], "path": ["api", "v1", "notificaciones", "proyecto", "1"] }
          }
        },
        {
          "name": "Marcar notificación como leída",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{notif_url}}/api/v1/notificaciones/1/read", "host": ["{{notif_url}}"], "path": ["api", "v1", "notificaciones", "1", "read"] }
          }
        }
      ]
    }
  ]
}
