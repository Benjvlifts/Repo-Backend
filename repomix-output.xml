  <description>Microservicio de Gestión de Recursos Humanos - Innovatech Solutions</description>

  <properties>
    <java.version>21</java.version>
    <!-- ── SonarCloud ── -->
    <!-- IMPORTANTE: reemplaza TU_ORG por el slug de tu organización en sonarcloud.io -->
