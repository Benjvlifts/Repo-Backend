					<!-- 2. Genera el reporte XML tras 'mvn verify' -->
					<execution>
						<id>report</id>
						<phase>verify</phase>
						<goals>
							<goal>report</goal>
						</goals>
					</execution>
				</executions>
			</plugin>

			<!-- ── SonarCloud scanner ── -->
			<!-- Ejecutar con: mvn verify sonar:sonar -Dsonar.token=TU_TOKEN -->
			<plugin>
